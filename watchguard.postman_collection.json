{
  "info": {
    "name": "Watch Guard API",
    "description": "AI-powered face recognition attendance & security system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('userId', res.data.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@watchguard.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth", "refresh"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth", "logout"] }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@watchguard.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth", "forgot-password"] }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"RESET_TOKEN_HERE\",\n  \"password\": \"newPassword123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["auth", "reset-password"] }
          }
        }
      ]
    },
    {
      "name": "Face Recognition",
      "item": [
        {
          "name": "Recognize Face (File Upload)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/face/recognize", "host": ["{{baseUrl}}"], "path": ["face", "recognize"] }
          }
        },
        {
          "name": "Recognize Face (Base64)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"image\": \"data:image/jpeg;base64,BASE64_DATA_HERE\",\n  \"cameraId\": \"camera-1\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/face/recognize", "host": ["{{baseUrl}}"], "path": ["face", "recognize"] }
          }
        },
        {
          "name": "Register Face",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "image", "type": "file", "src": "" },
                { "key": "name", "value": "Jane Smith", "type": "text" },
                { "key": "employeeId", "value": "EMP-011", "type": "text" },
                { "key": "department", "value": "Engineering", "type": "text" },
                { "key": "role", "value": "EMPLOYEE", "type": "text" }
              ]
            },
            "url": { "raw": "{{baseUrl}}/face/register", "host": ["{{baseUrl}}"], "path": ["face", "register"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\",\n  \"department\": \"Management\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["users", "{{userId}}"] }
          }
        }
      ]
    },
    {
      "name": "Attendance",
      "item": [
        {
          "name": "List Attendance Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendance?page=1&limit=20&search=&status=&dateFrom=&dateTo=",
              "host": ["{{baseUrl}}"],
              "path": ["attendance"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "" },
                { "key": "status", "value": "" },
                { "key": "dateFrom", "value": "" },
                { "key": "dateTo", "value": "" }
              ]
            }
          }
        },
        {
          "name": "Get Attendance Stats",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/attendance/stats", "host": ["{{baseUrl}}"], "path": ["attendance", "stats"] }
          }
        },
        {
          "name": "Export Attendance CSV",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendance/export?dateFrom=2024-01-01&dateTo=2024-12-31",
              "host": ["{{baseUrl}}"],
              "path": ["attendance", "export"],
              "query": [
                { "key": "dateFrom", "value": "2024-01-01" },
                { "key": "dateTo", "value": "2024-12-31" }
              ]
            }
          }
        },
        {
          "name": "Get User Attendance History",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/attendance/{{userId}}/history?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["attendance", "{{userId}}", "history"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        }
      ]
    },
    {
      "name": "Approvals",
      "item": [
        {
          "name": "List Pending Approvals",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/approvals", "host": ["{{baseUrl}}"], "path": ["approvals"] }
          }
        },
        {
          "name": "Approve Request",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/approvals/REQUEST_ID/approve", "host": ["{{baseUrl}}"], "path": ["approvals", "REQUEST_ID", "approve"] }
          }
        },
        {
          "name": "Reject Request",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/approvals/REQUEST_ID/reject", "host": ["{{baseUrl}}"], "path": ["approvals", "REQUEST_ID", "reject"] }
          }
        }
      ]
    },
    {
      "name": "Cameras",
      "item": [
        {
          "name": "List Cameras",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/cameras", "host": ["{{baseUrl}}"], "path": ["cameras"] }
          }
        },
        {
          "name": "Create Camera",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Front Gate Camera\",\n  \"location\": \"Main Entrance\",\n  \"streamUrl\": \"rtsp://192.168.1.100/stream\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/cameras", "host": ["{{baseUrl}}"], "path": ["cameras"] }
          }
        },
        {
          "name": "Update Camera",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Camera Name\",\n  \"isActive\": false\n}"
            },
            "url": { "raw": "{{baseUrl}}/cameras/CAMERA_ID", "host": ["{{baseUrl}}"], "path": ["cameras", "CAMERA_ID"] }
          }
        }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        {
          "name": "List Notifications",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/notifications", "host": ["{{baseUrl}}"], "path": ["notifications"] }
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/notifications/NOTIFICATION_ID/read", "host": ["{{baseUrl}}"], "path": ["notifications", "NOTIFICATION_ID", "read"] }
          }
        },
        {
          "name": "Mark All Read",
          "request": {
            "method": "PUT",
            "url": { "raw": "{{baseUrl}}/notifications/read-all", "host": ["{{baseUrl}}"], "path": ["notifications", "read-all"] }
          }
        }
      ]
    }
  ]
}
